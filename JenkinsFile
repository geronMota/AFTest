pipeline {
    agent any  // roda em qualquer agente disponível

    tools {
        // Se você configurou Maven no Jenkins Global Tool Configuration
        maven 'Maven'  // nome da instalação Maven no Jenkins
    }

    stages {
        stage('Checkout') {
            steps {
                // Já faz checkout automático, mas pode customizar
                echo 'Checkout do código do GitHub'
            }
        }

        stage('Build') {
            steps {
                bat 'mvn clean package'  // ou sh 'mvn ...' se for Linux
            }
        }

        stage('Test') {
            steps {
                bat 'mvn test'
            }
        }

        // Adicione mais stages: deploy, sonar, etc. depois
    }

    post {
        always {
            echo 'Pipeline finalizado!'
            // archiveArtifacts artifacts: 'target/*.jar', allowEmptyArchive: true
        }
    }
}